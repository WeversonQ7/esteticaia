# SUPABASE (banco de dados + auth + filas)
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# REDIS (Upstash - gratuito para cache e deduplicação)
REDIS_URL=rediss://default:sua-senha@seu-host.upstash.io:6379

# META / WHATSAPP BUSINESS API (oficial do Facebook)
META_ACCESS_TOKEN=seu-token-de-acesso-do-meta
META_PHONE_NUMBER_ID=seu-phone-number-id
META_BUSINESS_ACCOUNT_ID=seu-business-account-id
META_WEBHOOK_VERIFY_TOKEN=seu-token-de-verificacao-webhook

# GROQ (IA - mais barato e rápido que Claude)
GROQ_API_KEY=sua-chave-groq

# STRIPE (pagamentos)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BASICO=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_EMPRESARIAL=price_...

# APP
NEXT_PUBLIC_APP_URL=https://esteticaia.vercel.app
APP_SECRET=seu-secret-jwt-256-bits
